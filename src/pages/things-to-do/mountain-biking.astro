---
import BaseLayout from '../../layouts/BaseLayout.astro';

const bookingUrl = 'https://resnexus.com/resnexus/reservations/book/6C664BF8-3F89-4D87-9E83-DA82447501EB/';

const trails = [
  {
    name: 'Beckwourth Peak Trail',
    type: 'XC / Intermediate',
    distance: 'Varies',
    driveTime: 'Departs from High Camp',
    description: 'This trail starts right at your cabin door. A cross-country style ride that climbs through forest and opens up to sweeping mountain views near the summit. Intermediate riders will love the flow and the fact that you don\'t need to drive anywhere.',
    links: {
      trailforks: 'https://www.trailforks.com/trails/beckwourth-peak-trail/',
    },
  },
  {
    name: 'Mills Peak Trail',
    type: 'Downhill / Intermediate to Advanced',
    distance: '~14 miles',
    driveTime: '23 min from High Camp',
    description: 'One of the most popular mountain bike trails in the Lost Sierra. A long, fun descent through old-growth forest with bermed turns, rock gardens, and roots. Shuttle-friendly or pedal up for the full experience. This trail alone is worth the trip.',
    links: {
      trailforks: 'https://www.trailforks.com/trails/mills-peak/',
    },
  },
  {
    name: 'Mount Hough Trail System',
    type: 'Multi-trail Network / All Levels',
    distance: 'Multiple trails',
    driveTime: '54 min from High Camp',
    description: 'A full trail system near Quincy with options for every skill level. Flowy singletrack, technical climbs, and rewarding descents. Worth the drive for a full day of riding. The town of Quincy also has great food and a bike shop.',
    links: {
      trailforks: 'https://www.trailforks.com/region/mount-hough/',
    },
  },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Mountain Biking Trails near Beckwourth Peak",
  "description": "Ride Beckwourth Peak Trail, Mills Peak, and Mt. Hough trail systems. Mountain biking from your cabin door at High Camp.",
};
---

<BaseLayout
  title="Mountain Biking Trails near Beckwourth Peak"
  description="Ride Beckwourth Peak Trail, Mills Peak, and Mt. Hough trail systems. Mountain biking from your cabin door at High Camp."
  schema={schema}
>
  <!-- Page Header -->
  <section class="section page-header">
    <div class="container">
      <h1>Mountain Biking near Beckwourth Peak</h1>
      <p class="page-header__subtitle">The Lost Sierra has some of Northern California's best singletrack, and most of it is uncrowded. At High Camp, one trail starts right at your door, and two more world-class trail systems are less than an hour away.</p>
    </div>
  </section>

  <!-- Trail Cards -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__header">
        <h2>Top Trails</h2>
      </div>

      <div class="trails-list">
        {trails.map((trail) => (
          <div class="trail-card">
            <div class="trail-card__header">
              <h3>{trail.name}</h3>
              <div class="trail-card__meta">
                <span class="trail-tag">{trail.type}</span>
                <span>{trail.distance}</span>
                <span>{trail.driveTime}</span>
              </div>
            </div>
            <p>{trail.description}</p>
            <div class="trail-card__links">
              {trail.links.trailforks && (
                <a href={trail.links.trailforks} target="_blank" rel="noopener noreferrer" class="btn btn--ghost btn--small">View on TrailForks</a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Riding Info -->
  <section class="section">
    <div class="container">
      <div class="content-block">
        <h2>Plan Your Ride</h2>
        <ul class="info-list">
          <li><strong>Season:</strong> Trails are typically rideable from late May through October, depending on elevation and snowpack.</li>
          <li><strong>Bike wash:</strong> We have a hose at camp so you can clean your bike after every ride.</li>
          <li><strong>Bike storage:</strong> Secure storage available at your cabin, yurt, or campsite.</li>
          <li><strong>Nearest bike shop:</strong> Quincy has a full-service bike shop (about 54 minutes). Bring spare tubes and tools for trailside fixes.</li>
          <li><strong>Trail conditions:</strong> Check <a href="https://www.trailforks.com/" target="_blank" rel="noopener noreferrer">TrailForks</a> for current trail status before you ride.</li>
          <li><strong>Route advice:</strong> Forest (your host) rides these trails regularly and is happy to help you plan.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--dark cta-section">
    <div class="container text-center">
      <h2>Ride All Day, Sleep Well at Night</h2>
      <p>A real bed, hot showers, and trails from your door. Book your mountain bike trip.</p>
      <a href={bookingUrl} class="btn btn--ghost btn--large cta-btn" target="_blank" rel="noopener noreferrer">
        Check Availability
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding-top: var(--space-8);
    padding-bottom: var(--space-4);
  }

  .page-header h1 {
    margin-bottom: var(--space-2);
  }

  .page-header__subtitle {
    font-size: 1.25rem;
    color: var(--color-text-secondary);
    max-width: 700px;
  }

  .content-block {
    max-width: 800px;
  }

  .content-block h2 {
    margin-bottom: var(--space-2);
  }

  .trails-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .trail-card {
    background: var(--color-bg-primary);
    padding: var(--space-4);
    border-radius: var(--border-radius);
    border-left: 4px solid var(--color-primary);
  }

  .trail-card__header {
    margin-bottom: var(--space-2);
  }

  .trail-card h3 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .trail-card__meta {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
  }

  .trail-tag {
    background: var(--color-bg-accent);
    padding: 0.125rem 0.75rem;
    border-radius: var(--border-radius-sm);
    font-weight: 600;
    font-size: 0.875rem;
  }

  .trail-card p {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-2);
  }

  .trail-card__links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .info-list {
    list-style: none;
    padding: 0;
  }

  .info-list li {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-bg-accent);
    font-size: 1.0625rem;
  }

  .info-list li:last-child {
    border-bottom: none;
  }

  .cta-section h2 {
    color: #fff;
    margin-bottom: var(--space-2);
  }

  .cta-section p {
    color: rgba(255, 255, 255, 0.85);
    font-size: 1.125rem;
    margin: 0 auto var(--space-4);
    max-width: 500px;
  }

  .cta-btn {
    border-color: var(--color-accent);
    color: #fff;
  }

  .cta-btn:hover {
    background: var(--color-accent);
    color: var(--color-primary);
  }
</style>
