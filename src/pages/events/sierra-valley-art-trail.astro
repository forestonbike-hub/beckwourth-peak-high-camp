---
import BaseLayout from '../../layouts/BaseLayout.astro';

const bookingUrl = 'https://resnexus.com/resnexus/reservations/book/6C664BF8-3F89-4D87-9E83-DA82447501EB/';

const schema = {
  "@context": "https://schema.org",
  "@type": "LodgingBusiness",
  "name": "Beckwourth Peak High Camp - Sierra Valley Art & Ag Trail",
  "description": "Stay at Beckwourth Peak High Camp during the Sierra Valley Art & Ag Trail weekend. 14-minute drive to the start of the valley tour.",
  "url": "https://beckwourthpeakhighcamp.com/events/sierra-valley-art-trail/"
};
---

<BaseLayout
  title="Sierra Valley Art & Ag Trail"
  description="Stay at Beckwourth Peak High Camp during the Sierra Valley Art & Ag Trail weekend. 14-minute drive to the start of the valley tour."
  schema={schema}
>
  <!-- Hero -->
  <section class="page-hero">
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content container">
      <p class="page-hero__label">Sierra Valley Art &amp; Ag Trail</p>
      <h1>Art, Farms, and Mountain Views</h1>
      <p class="page-hero__subtitle">Stay at High Camp during the Sierra Valley Art &amp; Ag Trail weekend. Just a 14-minute drive to the start of the tour.</p>
      <a href={bookingUrl} class="btn btn--primary btn--large" target="_blank" rel="noopener noreferrer">
        Book Your Stay
      </a>
    </div>
  </section>

  <!-- About -->
  <section class="section">
    <div class="container">
      <div class="content-block">
        <h2>Explore the Sierra Valley's Creative Side</h2>
        <p>The Sierra Valley Art &amp; Ag Trail is a seasonal self-guided tour through the farms, studios, and galleries scattered across one of California's largest alpine valleys. It's a rare chance to meet the artists and ranchers who call this place home, sample local food, and discover the creative spirit of the Lost Sierra.</p>
        <p>High Camp sits just 14 minutes from the start of the valley tour, making it the perfect base for a weekend of exploring. Spend your days wandering the trail, and your evenings on the deck watching the sun set over the mountains.</p>

        <h3>Why Stay at High Camp</h3>
        <ul>
          <li>14-minute drive to the start of the Art &amp; Ag Trail</li>
          <li>Cabins, yurt, and campsite on 60 private acres</li>
          <li>Hot showers and Starlink WiFi</li>
          <li>Communal fire pit, perfect for unwinding after a day of exploring</li>
          <li>Disc golf, hiking, and mountain views right at camp</li>
          <li>A quiet mountain retreat away from the valley crowds</li>
        </ul>

        <h3>Make It a Weekend</h3>
        <p>The Art &amp; Ag Trail works beautifully as a full weekend trip. Drive up Friday evening, settle into your cabin or yurt, and spend Saturday and Sunday at your own pace on the trail. Between stops, you can hike to the Beckwourth Peak summit, play a round of disc golf, or just sit on the deck with a coffee and take in the views.</p>
        <p>It's the kind of weekend that doesn't need a packed itinerary. Just good art, good food, and a gorgeous place to come home to at the end of the day.</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--dark cta-section">
    <div class="container text-center">
      <h2>Reserve Your Weekend</h2>
      <p>Book a cabin, yurt, or campsite at High Camp and make the Art &amp; Ag Trail a proper getaway.</p>
      <a href={bookingUrl} class="btn btn--ghost btn--large cta-btn" target="_blank" rel="noopener noreferrer">
        Check Availability
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    position: relative;
    min-height: 50vh;
    display: flex;
    align-items: flex-end;
    background-image: url('/images/property/high-camp-hero.jpg');
    background-size: cover;
    background-position: center;
    padding-bottom: var(--space-8);
  }

  .page-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.6) 0%, rgba(0, 0, 0, 0.15) 60%, transparent 100%);
  }

  .page-hero__content {
    position: relative;
    z-index: 1;
    max-width: 650px;
  }

  .page-hero__label {
    color: var(--color-accent);
    font-weight: 700;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
  }

  .page-hero__content h1 {
    color: #fff;
    margin-bottom: var(--space-2);
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
  }

  .page-hero__subtitle {
    color: rgba(255, 255, 255, 0.9);
    font-size: 1.2rem;
    margin-bottom: var(--space-4);
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);
  }

  .content-block {
    max-width: 800px;
  }

  .content-block h2 {
    margin-bottom: var(--space-3);
  }

  .content-block h3 {
    margin-top: var(--space-4);
    margin-bottom: var(--space-2);
    font-size: 1.5rem;
  }

  .content-block ul {
    margin-bottom: 1.5rem;
  }

  .content-block li {
    font-size: 1.05rem;
    color: var(--color-text-secondary);
  }

  .cta-section h2 {
    color: #fff;
    margin-bottom: var(--space-2);
  }

  .cta-section p {
    color: rgba(255, 255, 255, 0.85);
    font-size: 1.125rem;
    margin: 0 auto var(--space-4);
    max-width: 500px;
  }

  .cta-btn {
    border-color: var(--color-accent);
    color: #fff;
  }

  .cta-btn:hover {
    background: var(--color-accent);
    color: var(--color-primary);
  }

  @media (max-width: 768px) {
    .page-hero {
      min-height: 40vh;
    }
  }
</style>
