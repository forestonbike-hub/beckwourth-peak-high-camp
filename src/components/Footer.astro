---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer__inner">
    <div class="footer__grid">
      <!-- Column 1: About -->
      <div class="footer__col">
        <h3 class="footer__heading">Beckwourth Peak High Camp</h3>
        <p class="footer__text">
          Off-grid glamping on 60 acres in the heart of the Lost Sierra. Cabins, yurt, and campsite near Portola, CA.
        </p>
        <div class="footer__social">
          <a href="https://www.instagram.com/highcamp_beckwourthpeak/" target="_blank" rel="noopener noreferrer" aria-label="Follow us on Instagram">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
          </a>
          <a href="https://www.facebook.com/beckwourthpeakhighcamp" target="_blank" rel="noopener noreferrer" aria-label="Follow us on Facebook">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
          </a>
        </div>
      </div>

      <!-- Column 2: Explore -->
      <div class="footer__col">
        <h3 class="footer__heading">Explore</h3>
        <ul class="footer__links">
          <li><a href="/lodging/">Lodging</a></li>
          <li><a href="/things-to-do/">Things to Do</a></li>
          <li><a href="/gallery/">Gallery</a></li>
          <li><a href="/about/">About Us</a></li>
          <li><a href="/blog/">Blog</a></li>
        </ul>
      </div>

      <!-- Column 3: Activities -->
      <div class="footer__col">
        <h3 class="footer__heading">Activities</h3>
        <ul class="footer__links">
          <li><a href="/things-to-do/gravel-biking/">Gravel Biking</a></li>
          <li><a href="/things-to-do/mountain-biking/">Mountain Biking</a></li>
          <li><a href="/things-to-do/hiking/">Hiking</a></li>
          <li><a href="/things-to-do/bikepacking/">Bikepacking</a></li>
          <li><a href="/things-to-do/ohv/">OHV / Off-Road</a></li>
        </ul>
      </div>

      <!-- Column 4: Contact -->
      <div class="footer__col">
        <h3 class="footer__heading">Contact</h3>
        <ul class="footer__links footer__contact">
          <li>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            <a href="mailto:info@beckwourthpeakhighcamp.com">info@beckwourthpeakhighcamp.com</a>
          </li>
          <li>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            <a href="tel:530-322-0322">530-322-0322</a>
          </li>
          <li>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            <a href="https://maps.app.goo.gl/YourLink" target="_blank" rel="noopener noreferrer">Near Portola, CA</a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Partner Logos -->
    <div class="footer__partners">
      <p class="footer__partners-label">We Proudly Support</p>
      <div class="footer__partners-logos">
        <img src="/images/logos/sierra-buttes-trail-stewardship.png" alt="Sierra Buttes Trail Stewardship" width="120" height="40" loading="lazy" />
        <img src="/images/logos/beckwourth-peak-recreation.png" alt="Beckwourth Peak Recreation" width="120" height="40" loading="lazy" />
        <img src="/images/logos/bdr.png" alt="Backcountry Discovery Routes" width="120" height="40" loading="lazy" />
        <img src="/images/logos/lost-sierra-mtb.png" alt="Lost Sierra MTB" width="120" height="40" loading="lazy" />
        <img src="/images/logos/adventure-cycling.png" alt="Adventure Cycling Association" width="120" height="40" loading="lazy" />
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="footer__bottom">
      <p>&copy; {currentYear} Beckwourth Peak High Camp. All rights reserved.</p>
      <div class="footer__legal">
        <a href="/policies/">Policies</a>
        <a href="/privacy-policy/">Privacy Policy</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-primary);
    color: var(--color-bg-primary);
    padding: var(--space-8) 0 var(--space-4);
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1.2fr;
    gap: var(--space-5);
    margin-bottom: var(--space-6);
  }

  .footer__heading {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-2);
  }

  .footer__text {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: rgba(250, 250, 247, 0.8);
    max-width: 300px;
  }

  .footer__social {
    display: flex;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }

  .footer__social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(250, 250, 247, 0.1);
    color: var(--color-bg-primary);
    text-decoration: none;
    transition: all var(--transition);
  }

  .footer__social a:hover {
    background: var(--color-accent);
    color: var(--color-primary);
  }

  .footer__links {
    list-style: none;
    padding: 0;
  }

  .footer__links li {
    margin-bottom: 0.625rem;
  }

  .footer__links a {
    color: rgba(250, 250, 247, 0.8);
    text-decoration: none;
    font-size: 0.9375rem;
    transition: color var(--transition);
  }

  .footer__links a:hover {
    color: var(--color-accent);
  }

  .footer__contact li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .footer__contact svg {
    flex-shrink: 0;
    color: var(--color-accent);
  }

  /* Partners */
  .footer__partners {
    border-top: 1px solid rgba(250, 250, 247, 0.15);
    border-bottom: 1px solid rgba(250, 250, 247, 0.15);
    padding: var(--space-4) 0;
    margin-bottom: var(--space-4);
    text-align: center;
  }

  .footer__partners-label {
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(250, 250, 247, 0.5);
    margin-bottom: var(--space-2);
  }

  .footer__partners-logos {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .footer__partners-logos img {
    height: 40px;
    width: auto;
    opacity: 0.8;
    filter: brightness(0) invert(1);
    transition: opacity var(--transition);
  }

  .footer__partners-logos img:hover {
    opacity: 1;
  }

  /* Bottom */
  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.8125rem;
    color: rgba(250, 250, 247, 0.5);
  }

  .footer__legal {
    display: flex;
    gap: var(--space-3);
  }

  .footer__legal a {
    color: rgba(250, 250, 247, 0.5);
    text-decoration: none;
    transition: color var(--transition);
  }

  .footer__legal a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 1024px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 768px) {
    .footer__grid {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }

    .footer__bottom {
      flex-direction: column;
      gap: var(--space-1);
      text-align: center;
    }
  }
</style>
